			"user_scripts": {
				"mouseMovement": "// Copy-paste the contents of this script into a layer's User Scripts\n// After that, clicking on a key will show mouse movement options.\nvar vx;\nvar vy;\n\nvar dxWheel;\nvar dyWheel;\n\nvar mouseMask; // 0 = up, 1 = down, 2 = left, 3 = right\nvar mouseWheelMask; // 0 = up, 1 = down, 2 = left, 3 = right\n\n// Scaled up *10\nconst MOUSE_MAX_VELOCITY = 2000; // 200\nconst MOUSE_ACCELERATION = 25;   // 2.5 units/tick\nconst DX_WHEEL = 1;\nconst DY_WHEEL = 1;\n\nfunc mouseUpPressed() {\n  mousePressed(1);\n}\n\nfunc mouseDownPressed() {\n  mousePressed(2);\n}\n\nfunc mouseLeftPressed() {\n  mousePressed(4);\n}\n\nfunc mouseRightPressed() {\n  mousePressed(8);\n}\n\nfunc mouseUpReleased() {\n  vy = 0;\n  mouseReleased(1);\n}\n\nfunc mouseDownReleased() {\n  vy = 0;\n  mouseReleased(2);\n}\n\nfunc mouseLeftReleased() {\n  vx = 0;\n  mouseReleased(4);\n}\n\nfunc mouseRightReleased() {\n  vx = 0;\n  mouseReleased(8);\n}\n\nfunc mouseWheelUpPressed() {\n  mouseWheelPressed(1);\n}\n\nfunc mouseWheelDownPressed() {\n  mouseWheelPressed(2);\n}\n\nfunc mouseWheelLeftPressed() {\n  mouseWheelPressed(4);\n}\n\nfunc mouseWheelRightPressed() {\n  mouseWheelPressed(8);\n}\n\nfunc mouseWheelUpReleased() {\n  mouseWheelReleased(1);\n}\n\nfunc mouseWheelDownReleased() {\n  mouseWheelReleased(2);\n}\n\nfunc mouseWheelLeftReleased() {\n  mouseWheelReleased(4);\n}\n\nfunc mouseWheelRightReleased() {\n  mouseWheelReleased(8);\n}\n\nfunc mousePressed(mask) {\n  mouseMask = mouseMask | mask;\n  startTimer(@updateMouse, 25, 1, @updateMouse);\n  updateMouse();\n}\n\nfunc mouseReleased(mask) {\n  mouseMask = mouseMask & ~mask;\n  if (mouseMask == 0) {\n    stopTimer(@updateMouse);\n  }\n}\n\nfunc mouseWheelPressed(mask) {\n  mouseWheelMask = mouseWheelMask | mask;\n  startTimer(@updateMouseWheel, 25, 1, @updateMouseWheel);\n  updateMouseWheel();\n}\n\nfunc mouseWheelReleased(mask) {\n  mouseWheelMask = mouseWheelMask & ~mask;\n  if (mouseWheelMask == 0) {\n    stopTimer(@updateMouseWheel);\n  }\n}\n\nfunc mouseReleaseAll() {\n  mouseMask = 0;\n  stopTimer(@updateMouse);\n}\n\nfunc updateMouse() {\n  var upDown = mouseMask & 3;\n  if (upDown == 0 || upDown == 3) {\n    vy = 0;\n  } else if(upDown == 1) {\n    vy = vy - MOUSE_ACCELERATION;\n    if (vy < -MOUSE_MAX_VELOCITY) vy = -MOUSE_MAX_VELOCITY;\n  } else {\n    vy = vy + MOUSE_ACCELERATION;\n    if (vy > MOUSE_MAX_VELOCITY) vy = MOUSE_MAX_VELOCITY;\n  }\n\n  var leftRight = mouseMask >> 2;\n  if (leftRight == 0 || leftRight == 3) {\n    vx = 0;\n  } else if(leftRight == 1) {\n    vx = vx - MOUSE_ACCELERATION;\n    if (vx < -MOUSE_MAX_VELOCITY) vx = -MOUSE_MAX_VELOCITY;\n  } else {\n    vx = vx + MOUSE_ACCELERATION;\n    if (vx > MOUSE_MAX_VELOCITY) vx = MOUSE_MAX_VELOCITY;\n  }\n\n  moveMouse(vx/10, vy/10);\n}\n\nfunc updateMouseWheel() {\n  var upDown = mouseWheelMask & 3;\n  if (upDown == 0 || upDown == 3) {\n    dyWheel = 0;\n  } else if(upDown == 1) {\n    dyWheel = DY_WHEEL;\n  } else {\n    dyWheel = -1*DY_WHEEL;\n  }\n\n  var leftRight = mouseWheelMask >> 2;\n  if (leftRight == 0 || leftRight == 3) {\n    dxWheel = 0;\n  } else if(leftRight == 1) {\n    dxWheel = -1*DX_WHEEL;\n  } else {\n    dxWheel = DX_WHEEL;\n  }\n\n  vWheelMouse(dyWheel);\n  hWheelMouse(dxWheel);\n}\n\n// #prefab Mouse:Up [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// Mouse\\\\nUp\\nmouseUpPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"//\\nmouseUpReleased();\"}}}]\n// #prefab Mouse:Down [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// Mouse\\\\nDown\\nmouseDownPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// \\nmouseDownReleased();\"}}}]\n// #prefab Mouse:Left [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// Mouse\\\\nLeft\\nmouseLeftPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"//\\nmouseLeftReleased();\"}}}]\n// #prefab Mouse:Right [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// Mouse\\\\nRight\\nmouseRightPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// \\nmouseRightReleased();\"}}}]\n// #prefab MouseWheel:Up [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// MouseWheel\\\\nUp\\nmouseWheelUpPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"//\\nmouseWheelUpReleased();\"}}}]\n// #prefab MouseWheel:Down [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// MouseWheel\\\\nDown\\nmouseWheelDownPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// \\nmouseWheelDownReleased();\"}}}]\n// #prefab MouseWheel:Left [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// MouseWheel\\\\nLeft\\nmouseWheelLeftPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"//\\nmouseWheelLeftReleased();\"}}}]\n// #prefab MouseWheel:Right [{\"t\":\"p\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// MouseWheel\\\\nRight\\nmouseWheelRightPressed();\"}}},{\"t\":\"r\",\"d\":{\"a\":{\"t\":\"s\",\"script\":\"// \\nmouseWheelRightReleased();\"}}}]\n"
			},
