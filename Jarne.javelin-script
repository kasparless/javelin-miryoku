func mouseWheelLeftReleased() {
  mouseWheelReleased(4);
}

func mouseWheelRightReleased() {
  mouseWheelReleased(8);
}

func mousePressed(mask) {
  mouseMask = mouseMask | mask;
  startTimer(@updateMouse, 25, 1, @updateMouse);
  updateMouse();
}

func mouseReleased(mask) {
  mouseMask = mouseMask & ~mask;
  if (mouseMask == 0) {
    stopTimer(@updateMouse);
  }
}

func mouseWheelPressed(mask) {
  mouseWheelMask = mouseWheelMask | mask;
  startTimer(@updateMouseWheel, 25, 1, @updateMouseWheel);
  updateMouseWheel();
}

func mouseWheelReleased(mask) {
  mouseWheelMask = mouseWheelMask & ~mask;
  if (mouseWheelMask == 0) {
    stopTimer(@updateMouseWheel);
  }
}

func mouseReleaseAll() {
  mouseMask = 0;
  stopTimer(@updateMouse);
}

func updateMouse() {
  var upDown = mouseMask & 3;
  if (upDown == 0 || upDown == 3) {
    vy = 0;
  } else if(upDown == 1) {
    vy = vy - MOUSE_ACCELERATION;
    if (vy < -MOUSE_MAX_VELOCITY) vy = -MOUSE_MAX_VELOCITY;
  } else {
    vy = vy + MOUSE_ACCELERATION;
    if (vy > MOUSE_MAX_VELOCITY) vy = MOUSE_MAX_VELOCITY;
  }

  var leftRight = mouseMask >> 2;
  if (leftRight == 0 || leftRight == 3) {
    vx = 0;
  } else if(leftRight == 1) {
    vx = vx - MOUSE_ACCELERATION;
    if (vx < -MOUSE_MAX_VELOCITY) vx = -MOUSE_MAX_VELOCITY;
  } else {
    vx = vx + MOUSE_ACCELERATION;
    if (vx > MOUSE_MAX_VELOCITY) vx = MOUSE_MAX_VELOCITY;
  }

  moveMouse(vx/10, vy/10);
}

func updateMouseWheel() {
  var upDown = mouseWheelMask & 3;
  if (upDown == 0 || upDown == 3) {
    dyWheel = 0;
  } else if(upDown == 1) {
    dyWheel = DY_WHEEL;
  } else {
    dyWheel = -1*DY_WHEEL;
  }

  var leftRight = mouseWheelMask >> 2;
  if (leftRight == 0 || leftRight == 3) {
    dxWheel = 0;
  } else if(leftRight == 1) {
    dxWheel = -1*DX_WHEEL;
  } else {
    dxWheel = DX_WHEEL;
  }

  vWheelMouse(dyWheel);
  hWheelMouse(dxWheel);
}

