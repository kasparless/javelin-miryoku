// Copy-paste the contents of this script into a layer's User Scripts
// After that, clicking on a key will show mouse movement options.
var vx;
var vy;

var dxWheel;
var dyWheel;

var mouseMask; // 0 = up, 1 = down, 2 = left, 3 = right
var mouseWheelMask; // 0 = up, 1 = down, 2 = left, 3 = right

// Scaled up *10
const MOUSE_MAX_VELOCITY = 2000; // 200
const MOUSE_ACCELERATION = 25;   // 2.5 units/tick
const DX_WHEEL = 1;
const DY_WHEEL = 1;

func mouseUpPressed() {
  mousePressed(1);
}

func mouseDownPressed() {
  mousePressed(2);
}

func mouseLeftPressed() {
  mousePressed(4);
}

func mouseRightPressed() {
  mousePressed(8);
}

func mouseUpReleased() {
  vy = 0;
  mouseReleased(1);
}

func mouseDownReleased() {
  vy = 0;
  mouseReleased(2);
}

func mouseLeftReleased() {
  vx = 0;
  mouseReleased(4);
}

func mouseRightReleased() {
  vx = 0;
  mouseReleased(8);
}

func mouseWheelUpPressed() {
  mouseWheelPressed(1);
}

func mouseWheelDownPressed() {
  mouseWheelPressed(2);
}

func mouseWheelLeftPressed() {
  mouseWheelPressed(4);
}

